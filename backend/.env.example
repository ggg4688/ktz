DIGITAL_TWIN_DB_PATH=data/telemetry.db
DIGITAL_TWIN_AUTO_START_SIMULATOR=true
DIGITAL_TWIN_DEFAULT_LOCOMOTIVE_ID=locomotive-01
DIGITAL_TWIN_CORS_ORIGINS=*
DIGITAL_TWIN_JWT_SECRET=demo-jwt-secret-change-me
DIGITAL_TWIN_JWT_ISSUER=digital-twin-backend
DIGITAL_TWIN_JWT_ACCESS_TOKEN_TTL_MINUTES=60
# Used only to seed users into an empty database.
DIGITAL_TWIN_USERS_PATH=app/users.json
# Used only to seed the first health-model config into an empty database.
DIGITAL_TWIN_CONFIG_PATH=app/settings.json
